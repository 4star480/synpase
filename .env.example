# ── Required ──────────────────────────────────────────────
DATABASE_URL="file:./dev.db"
SESSION_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# Public site URL (crypto callbacks, absolute links)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Admin password when running db:seed / db:deploy (change on production)
ADMIN_PASSWORD="admin123456"

# ── Optional — crypto payments ────────────────────────────
# https://nowpayments.io/
NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_IPN_SECRET=""
CRYPTO_INVOICE_TTL_MINUTES="30"
ALLOW_CRYPTO_SIMULATE="1"

# ── Optional — deploy seed ────────────────────────────────
# SKIP_IMAGE_DOWNLOAD="1"

# ── PostgreSQL example (Vercel / Neon / Docker) ─────────
# DATABASE_URL="postgresql://gametrade:gametrade@localhost:5432/gametrade"
